%% THREAT GRAPH FLOW — IOC relationship mapping via VirusTotal
%% ============================================================

  subgraph GraphUI_SG["🖥️ Graph Page"]
    G_Input["Select IOC or Recent Scan"]
    G_Viz["Relationship Graph (nodes and edges)"]
  end

  subgraph GraphAPI_SG["⚙️ Graph API — GET /api/graph-v2"]
    G_Auth{"Verify JWT"}
    G_Cache{"OpenSearch Cache Check"}
    G_Builder["VT Graph Builder (map related IPs, domains, files, URLs)"]
  end

  subgraph GraphExternal_SG["🌐 VirusTotal Graph API"]
    G_VT["VirusTotal Relationship Endpoints"]
  end

  subgraph GraphStore_SG["🗄️ OpenSearch"]
    G_OS[("Graph Cache — per IOC value)"]
  end

  G_Input -->|"IOC value"| G_Auth
  G_Auth -->|"unauthorized"| G_Input
  G_Auth -->|"valid"| G_Cache
  G_Cache -->|"cache HIT"| G_Viz
  G_Cache -->|"cache MISS"| G_Builder
  G_Builder -->|"fetch relationships"| G_VT
  G_VT -->|"graph relationship data"| G_Builder
  G_Builder -->|"save graph"| G_OS
  G_Builder -->|"nodes and edges"| G_Viz
